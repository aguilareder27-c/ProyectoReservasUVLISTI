@page
@model ReservaEspacios.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Iniciar sesión";
}
<h2>Iniciar sesión</h2>
@if (Model.Error != null)
{
    <div class="alert alert-danger">@Model.Error</div>
}
<form method="post" style="max-width:420px">
    <div class="mb-3">
        <label class="form-label">Correo</label>
        <input class="form-control" asp-for="Correo" type="email" required />
    </div>
    <div class="mb-3">
        <label class="form-label">Contraseña</label>
        <input class="form-control" asp-for="Contrasena" type="password" required />
    </div>
    <button class="btn btn-primary" type="submit">Entrar</button>
    <a class="btn btn-link" asp-page="/Account/Register">Crear cuenta</a>
</form>
