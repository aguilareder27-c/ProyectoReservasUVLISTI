@page
@model ReservaEspacios.Pages.Admin.Espacios.EditarModel
@{
    ViewData["Title"] = Model.EsNuevo ? "Nuevo espacio" : "Editar espacio";
    var dias = new[] { (1,"Lunes"),(2,"Martes"),(3,"Miércoles"),(4,"Jueves"),(5,"Viernes"),(6,"Sábado"),(7,"Domingo") };
}
<h2>@ViewData["Title"]</h2>
@if (Model.Error != null)
{
    <div class="alert alert-danger">@Model.Error</div>
}
<form method="post" style="max-width:560px">
    <input type="hidden" asp-for="Id" />
    <div class="mb-3">
        <label class="form-label">Nombre</label>
        <input class="form-control" asp-for="Nombre" required />
    </div>
    <div class="row mb-3">
        <div class="col">
            <label class="form-label">Tipo</label>
            <input class="form-control" asp-for="Tipo" placeholder="auditorio, sala…" />
        </div>
        <div class="col">
            <label class="form-label">Capacidad</label>
            <input class="form-control" type="number" asp-for="Capacidad" min="1" required />
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label">Ubicación</label>
        <input class="form-control" asp-for="Ubicacion" />
    </div>
    <div class="mb-3">
        <label class="form-label">Descripción</label>
        <textarea class="form-control" asp-for="Descripcion" rows="2"></textarea>
    </div>
    <div class="row mb-3">
        <div class="col">
            <label class="form-label">Hora apertura</label>
            <input class="form-control" type="time" asp-for="HoraApertura" />
        </div>
        <div class="col">
            <label class="form-label">Hora cierre</label>
            <input class="form-control" type="time" asp-for="HoraCierre" />
        </div>
        <div class="col">
            <label class="form-label">Estado</label>
            <select class="form-select" asp-for="EstadoStr">
                <option value="Disponible">Disponible</option>
                <option value="Inactivo">Inactivo</option>
            </select>
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label d-block">Días de operación</label>
        @foreach (var (val, nom) in dias)
        {
            <div class="form-check form-check-inline">
                <input class="form-check-input" type="checkbox" name="Dias" value="@val"
                       id="dia-@val" @(Model.Dias.Contains(val) ? "checked" : "") />
                <label class="form-check-label" for="dia-@val">@nom</label>
            </div>
        }
    </div>
    <button class="btn btn-primary" type="submit">Guardar</button>
    <a class="btn btn-link" asp-page="/Admin/Espacios/Index">Cancelar</a>
</form>
